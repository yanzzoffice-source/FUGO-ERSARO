local function createSmallButton(name, callback)
    local Btn = Instance.new("TextButton")
    Btn.Name = name:gsub("%s", "_") .. "Btn"
    Btn.Parent = ScrollingFrame
    Btn.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    Btn.BackgroundTransparency = 0.88
    Btn.BorderSizePixel = 0
    Btn.Size = UDim2.new(1, -2, 0, 28)
    Btn.Font = Enum.Font.GothamSemibold
    Btn.Text = name
    Btn.TextColor3 = Color3.fromRGB(0, 255, 200)
    Btn.TextSize = 10
    Btn.AutoButtonColor = false
    Btn.ZIndex = 10
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 5)

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Parent = Btn
    BtnStroke.Color = Color3.fromRGB(0, 255, 255)
    BtnStroke.Transparency = 0.5
    BtnStroke.Thickness = 0.8

    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.8}):Play()
        TweenService:Create(BtnStroke, TweenInfo.new(0.15), {Transparency = 0.2}):Play()
    end)
    Btn.MouseLeave:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.88}):Play()
        TweenService:Create(BtnStroke, TweenInfo.new(0.15), {Transparency = 0.5}):Play()
    end)
    Btn.MouseButton1Click:Connect(callback)
end

