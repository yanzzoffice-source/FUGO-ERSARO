local function createSlider(name, min, max, default, callback)
    local Sf = Instance.new("Frame")
    Sf.Name = name .. "Slider"
    Sf.Parent = ScrollingFrame
    Sf.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    Sf.BackgroundTransparency = 0.94
    Sf.BorderSizePixel = 0
    Sf.Size = UDim2.new(1, -2, 0, 28)
    Sf.ZIndex = 10
    Instance.new("UICorner", Sf).CornerRadius = UDim.new(0, 6)

    local Nl = Instance.new("TextLabel")
    Nl.Parent = Sf; Nl.BackgroundTransparency = 1
    Nl.Position = UDim2.new(0, 10, 0, 0); Nl.Size = UDim2.new(0, 65, 1, 0)
    Nl.Font = Enum.Font.GothamSemibold; Nl.Text = name
    Nl.TextColor3 = Color3.fromRGB(180, 200, 200); Nl.TextSize = 10
    Nl.TextXAlignment = Enum.TextXAlignment.Left; Nl.ZIndex = 10

    local Vl = Instance.new("TextLabel")
    Vl.Name = "Value"; Vl.Parent = Sf; Vl.BackgroundTransparency = 1
    Vl.Position = UDim2.new(1, -40, 0, 0); Vl.Size = UDim2.new(0, 36, 1, 0)
    Vl.Font = Enum.Font.GothamBold; Vl.Text = tostring(default)
    Vl.TextColor3 = Color3.fromRGB(0, 255, 200); Vl.TextSize = 10; Vl.ZIndex = 10

    local Sbg = Instance.new("Frame")
    Sbg.Name = "SliderBg"; Sbg.Parent = Sf
    Sbg.BackgroundColor3 = Color3.fromRGB(15, 25, 35); Sbg.BorderSizePixel = 0
    Sbg.Position = UDim2.new(0, 78, 0.5, -3); Sbg.Size = UDim2.new(1, -126, 0, 6); Sbg.ZIndex = 10
    Instance.new("UICorner", Sbg).CornerRadius = UDim.new(0, 3)

    local Sfl = Instance.new("Frame")
    Sfl.Name = "Fill"; Sfl.Parent = Sbg
    Sfl.BackgroundColor3 = Color3.fromRGB(0, 255, 200); Sfl.BorderSizePixel = 0
    Sfl.Size = UDim2.new((default - min) / (max - min), 0, 1, 0); Sfl.ZIndex = 10
    Instance.new("UICorner", Sfl).CornerRadius = UDim.new(0, 3)

    local Sb = Instance.new("TextButton")
    Sb.Name = "SliderBtn"; Sb.Parent = Sbg
    Sb.BackgroundColor3 = Color3.fromRGB(0, 255, 255); Sb.BorderSizePixel = 0
    Sb.Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7)
    Sb.Size = UDim2.new(0, 14, 0, 14); Sb.Text = ""; Sb.AutoButtonColor = false; Sb.ZIndex = 11
    Instance.new("UICorner", Sb).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", Sb).Color = Color3.fromRGB(255, 255, 255); Instance.new("UIStroke", Sb).Thickness = 1

    local function setSlider(input)
        local pos = math.clamp((input.Position.X - Sbg.AbsolutePosition.X) / Sbg.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * pos)
        Sfl.Size = UDim2.new(pos, 0, 1, 0); Sb.Position = UDim2.new(pos, -7, 0.5, -7); Vl.Text = tostring(value)
        callback(value)
    end

    local dc, rc = nil, nil
    Sb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if dc then dc:Disconnect() end; if rc then rc:Disconnect() end
            dc = UserInputService.InputChanged:Connect(function(m)
                if m.UserInputType == Enum.UserInputType.MouseMovement or m.UserInputType == Enum.UserInputType.Touch then setSlider(m) end
            end)
            rc = UserInputService.InputEnded:Connect(function(e)
                if e.UserInputType == Enum.UserInputType.MouseButton1 or e.UserInputType == Enum.UserInputType.Touch then
                    if dc then dc:Disconnect(); dc = nil end; if rc then rc:Disconnect(); rc = nil end
                end
            end)
        end
    end)
    Sbg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then setSlider(i) end
    end)
end

