function enableESP()
    if Connections.ESP then Connections.ESP:Disconnect() end
    Connections.ESP = RunService.RenderStepped:Connect(function()
        pcall(function()
            for _, p in pairs(Players:GetPlayers()) do
                if p == LocalPlayer then continue end
                local char = p.Character
                if not char then
                    if ESPObjects[p] then
                        ESPObjects[p].Box.Visible = false; ESPObjects[p].Name.Visible = false
                        ESPObjects[p].Tracer.Visible = false
                        if ESPObjects[p].HealthBar then ESPObjects[p].HealthBar.Visible = false end
                    end
                    continue
                end
                local head = char:FindFirstChild("Head")
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if not head or not root then continue end
                local hp, hs = Camera:WorldToViewportPoint(head.Position)
                local rp = Camera:WorldToViewportPoint(root.Position)
                if hs then
                    local esp = ESPObjects[p]
                    if not esp then
                        esp = {
                            Box = Drawing.new("Square"), Name = Drawing.new("Text"), Tracer = Drawing.new("Line"),
                            HealthBg = Drawing.new("Square"), HealthBar = Drawing.new("Square")
                        }
                        esp.Box.Visible = false; esp.Box.Thickness = 2; esp.Box.Filled = false
                        esp.Name.Visible = false; esp.Name.Size = 13; esp.Name.Center = true; esp.Name.Outline = true
                        esp.Name.OutlineColor = Color3.fromRGB(0,0,0)
                        esp.Tracer.Visible = false; esp.Tracer.Thickness = 1
                        esp.HealthBg.Visible = false; esp.HealthBg.Thickness = 1; esp.HealthBg.Filled = true
                        esp.HealthBg.Color = Color3.fromRGB(0,0,0)
                        esp.HealthBar.Visible = false; esp.HealthBar.Thickness = 1; esp.HealthBar.Filled = true
                        ESPObjects[p] = esp
                    end
                    local bh = math.abs(hp.Y - rp.Y); local bw = bh * 0.55
                    local bx = hp.X - bw/2; local by = hp.Y - bh*0.1
                    local dist = (Camera.CFrame.Position - root.Position).Magnitude
                    
                    esp.Box.Visible = true; esp.Box.Size = Vector2.new(bw, bh); esp.Box.Position = Vector2.new(bx, by)
                    if dist < 20 then esp.Box.Color = Color3.fromRGB(0,255,200)
                    elseif dist < 50 then esp.Box.Color = Color3.fromRGB(255,200,0)
                    else esp.Box.Color = Color3.fromRGB(200,200,200) end
                    
                    esp.Name.Visible = true; esp.Name.Text = p.Name .. " [" .. math.floor(dist) .. "m]"
                    esp.Name.Position = Vector2.new(hp.X, by-16); esp.Name.Color = Color3.fromRGB(255,255,255)
                    
                    esp.Tracer.Visible = true; esp.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    esp.Tracer.To = Vector2.new(hp.X, rp.Y); esp.Tracer.Color = Color3.fromRGB(0,255,200)
                    
                    if hum then
                        local h = hum.Health / hum.MaxHealth
                        local bX = bx-6; local bY = by; local bW = 3; local bH = bh
                        esp.HealthBg.Visible = true; esp.HealthBg.Size = Vector2.new(bW, bH); esp.HealthBg.Position = Vector2.new(bX, bY)
                        esp.HealthBar.Visible = true; esp.HealthBar.Size = Vector2.new(bW, bH*h)
                        esp.HealthBar.Position = Vector2.new(bX, bY+bH*(1-h))
                        if h > 0.7 then esp.HealthBar.Color = Color3.fromRGB(0,255,150)
                        elseif h > 0.3 then esp.HealthBar.Color = Color3.fromRGB(255,200,0)
                        else esp.HealthBar.Color = Color3.fromRGB(255,50,50) end
                    else esp.HealthBg.Visible = false; esp.HealthBar.Visible = false end
                else
                    if ESPObjects[p] then
                        ESPObjects[p].Box.Visible = false; ESPObjects[p].Name.Visible = false
                        ESPObjects[p].Tracer.Visible = false; ESPObjects[p].HealthBg.Visible = false
                        ESPObjects[p].HealthBar.Visible = false
                    end
                end
            end
        end)
    end)
end

function disableESP()
    if Connections.ESP then Connections.ESP:Disconnect(); Connections.ESP = nil end
    for _, e in pairs(ESPObjects) do
        pcall(function()
            e.Box:Remove(); e.Name:Remove(); e.Tracer:Remove()
            if e.HealthBg then e.HealthBg:Remove() end; if e.HealthBar then e.HealthBar:Remove() end
        end)
    end
    ESPObjects = {}
end

function setSpeed(v) pcall(function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.WalkSpeed = v end end) end
function setJump(v) pcall(function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.JumpPower = v; LocalPlayer.Character.Humanoid.UseJumpPower = true end end) end

function enableNoclip()
    if NoclipConnection then NoclipConnection:Disconnect() end
    NoclipConnection = RunService.Stepped:Connect(function()
        pcall(function() if LocalPlayer.Character then for _, p in pairs(LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") and p.CanCollide then p.CanCollide = false end end end end)
    end)
end

function disableNoclip()
    if NoclipConnection then NoclipConnection:Disconnect(); NoclipConnection = nil end
    pcall(function() if LocalPlayer.Character then for _, p in pairs(LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end end end)
end

function enableFly()
    local char = LocalPlayer.Character; if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart"); local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    if flyBodyVelocity then flyBodyVelocity:Destroy() end; if flyBodyGyro then flyBodyGyro:Destroy() end
    flyBodyGyro = Instance.new("BodyGyro"); flyBodyGyro.Parent = root
    flyBodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000); flyBodyGyro.P = 30000; flyBodyGyro.D = 1000
    flyBodyGyro.CFrame = Camera.CFrame
    flyBodyVelocity = Instance.new("BodyVelocity"); flyBodyVelocity.Parent = root
    flyBodyVelocity.MaxForce = Vector3.new(400000, 400000, 400000); flyBodyVelocity.Velocity = Vector3.zero
    hum.PlatformStand = true
    flyConnection = RunService.Heartbeat:Connect(function()
        if not flyBodyGyro or not flyBodyGyro.Parent then disableFly(); return end
        flyBodyGyro.CFrame = Camera.CFrame
        local dir = Vector3.zero
        if flyKeys["W"] then dir = dir + Camera.CFrame.LookVector * CONFIG.FlySpeed end
        if flyKeys["S"] then dir = dir - Camera.CFrame.LookVector * CONFIG.FlySpeed end
        if flyKeys["A"] then dir = dir - Camera.CFrame.RightVector * CONFIG.FlySpeed end
        if flyKeys["D"] then dir = dir + Camera.CFrame.RightVector * CONFIG.FlySpeed end
        if flyKeys["Space"] then dir = dir + Vector3.new(0, CONFIG.FlySpeed, 0) end
        if flyKeys["LeftShift"] or flyKeys["RightShift"] then dir = dir - Vector3.new(0, CONFIG.FlySpeed, 0) end
        flyBodyVelocity.Velocity = dir
    end)
end

function disableFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    pcall(function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.PlatformStand = false end end)
    flyKeys = {}
end

function setFullbright(s)
    if s then Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.FogEnd = 100000; Lighting.GlobalShadows = false; Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
    else Lighting.Brightness = 1; Lighting.ClockTime = 14; Lighting.FogEnd = 1000; Lighting.GlobalShadows = true; Lighting.OutdoorAmbient = Color3.fromRGB(0,0,0) end
end

function enableAntiAFK()
    if Connections.AntiAFK then Connections.AntiAFK:Disconnect() end
    Connections.AntiAFK = RunService.Heartbeat:Connect(function() pcall(function() VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, nil); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, nil) end) end)
end

function disableAntiAFK() if Connections.AntiAFK then Connections.AntiAFK:Disconnect(); Connections.AntiAFK = nil end end

function teleportTo(x, y, z)
    pcall(function() if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(x, y, z)) end end)
end

function enableLockTp(x, y, z)
    if TpConnection then TpConnection:Disconnect() end
    local target = Vector3.new(x, y, z)
    TpConnection = RunService.Heartbeat:Connect(function()
        pcall(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                if (LocalPlayer.Character.HumanoidRootPart.Position - target).Magnitude > 5 then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(target)
                end
            end
        end)
    end)
end

function disableLockTp() if TpConnection then TpConnection:Disconnect(); TpConnection = nil end end

